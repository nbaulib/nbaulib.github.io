---
interface Props {
    href?: string;
    class?: string;
}

const { href, class: className } = Astro.props;
const isExternal = href?.startsWith("http");
---

<a
    href={href}
    class={className}
    target={isExternal ? "_blank" : undefined}
    rel={isExternal ? "noopener noreferrer" : undefined}><slot /></a
>
