---
import { Image } from "astro:assets";
import github from "/src/assets/github.svg";
import linkedin from "/src/assets/linkedin.svg";
---

<div class="nav">
    <div class="brand">
        <a href="/">
            <span class="first-name">NiCO</span>
            <span class="last-name">BAUTiSTA-LiBREROS</span>
            <span class="last-name-small">BL</span>
        </a>
    </div>

    <nav class="nav-links">
        <a href="/">Works</a>
        <a href="/teaching">Teaching</a>
    </nav>

    <div class="bio">
        <div>
            <p>An <b>interactive designer</b> focused on:</p>
            <ul>
                <li>UX 🧭</li>
                <li>web 🌐</li>
                <li>product 📦</li>
            </ul>
        </div>
        <p>
            Hunter College<br />
            CS + Media Studies<br />
            Dec 2026
        </p>

        <!-- <pre
            class="bio-ascii">
        _
       (c).-.
hi  .-" , _( )____)
        </pre> -->
    </div>

    <ul class="socials">
        <li>
            <a href="https://github.com/nbaulib" target="_blank">
                 <Image src={github} alt="Github logo" />
            </a>
        </li>
        <li>
            <a href="https://www.linkedin.com/in/nbaulib" target="_blank">
                <Image src={linkedin} alt="Linkedin logo" />
            </a>
        </li>
    </ul>
</div>

<style>
    /*** ***/
    :root {
        --nav-width: 220px;
    }

    /*** ***/
    .nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 24px;
        background: var(--dark);

        /* All text inside the nav inherits the light colour */
        color: var(--light);
    }

    /*** Logo Area - Brand ***/

    .brand a {
        font-family: "Stack Sans Notch", system-ui, sans-serif;
        font-weight: 500;
        letter-spacing: -0.01em;
        font-size: 1.25rem;
    }

    /*** Horizontal links (mobile) ***/
    .nav-links {
        display: flex;
        gap: 20px;
    }

    /*** Bio + socials hidden on mobile ***/
    .bio,
    .socials {
        display: none;
    }

    /* smaller last name on mobile */
    .last-name-small {
        display: none;
    }
    @media (max-width: 490px) {
        .last-name {
            display: none;
        }
        .last-name-small {
            display: inline;
        }
    }

    /*** Desktop: vertical sidebar ***/
    @media (min-width: 950px) {
        .nav {
            position: fixed;
            left: 0;
            top: 0;

            width: var(--nav-width);
            height: 100vh;

            flex-direction: column;
            align-items: flex-start;
            justify-content: flex-start;

            padding: 32px 24px;
            gap: 32px;

            /* Keep the sidebar on top of page content */
            z-index: 100;
        }

        /* bigger name logo */
        .brand {
            padding: 2rem 0px 0px 0px;
        }

        .brand a {
            line-height: 0;
        }

        span.first-name {
            font-weight: 600;
            font-size: 4rem;
        }

        span.last-name {
            font-weight: 600;
            font-size: 1rem;
        }

        .nav-links {
            flex-direction: column;
            gap: 12px;
            font-size: 1.1rem;
            font-weight: 400;
        }

        .bio {
            display: flex;
            flex-direction: column;
            font-size: 0.85rem;
            line-height: 1.6em;
            color: color-mix(in srgb, var(--light) 85%, transparent);
        }

        .bio b {
            opacity: 1;
            color: color-mix(in srgb, var(--light) 95%, transparent);
        }

        .bio p {
            /* line-height: 1.4em; */
        }

        .bio ul {
            list-style-type: square;
        }

        .bio-ascii {
            font-size: 0.5rem;
            line-height: 1;
            margin: 0;
            /* display: none; */
        }

        .socials {
            display: flex;
            gap: 12px;
            list-style: none;
            padding: 0;
            margin: 0;
            margin-top: auto;
            /* push to the bottom of the sidebar */
        }

        .socials li {
            display: flex;
            align-items: center;
        }

        /* ccan i make it cyan on hover? */
        .socials img {
            display: flex;
            width: 21px;
            filter: invert(1);
            opacity: 0.75;
            transition:
                filter 0.15s ease,
                opacity 0.15s ease;
        }

        .socials a:hover img {
            opacity: 1;
            filter: invert(1) sepia(1) saturate(10000%) hue-rotate(155deg);
        }
    }
</style>
