---
interface ImageItem {
  src: string;
  alt: string;
}

interface Props {
  images: ImageItem[];
}

const { images } = Astro.props;
---

<div class="image-row">
  {images.map((img) => (
    <img src={img.src} alt={img.alt} />
  ))}
</div>

<style>
  .image-row {
    display: flex;
    
    width: calc(40vw - var(--nav-width));
    gap: 0.5rem;
  }

  .image-row img {
    flex: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>